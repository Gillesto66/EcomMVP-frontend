# Auteur : Gilles - Projet : AGC Space - Module : Configuration Frontend
# Copier en .env.local

# ── URL du backend Django ─────────────────────────────────────────────────────
# Développement local (Next.js et Django sur la même machine) :
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production Vercel → backend Ngrok (à définir dans le dashboard Vercel, PAS ici) :
# NEXT_PUBLIC_API_URL=https://pomological-unlucidly-su.ngrok-free.dev

# Durée de vie du cookie d'affiliation (jours)
NEXT_PUBLIC_AFFILIATION_COOKIE_DAYS=30

# ── Builder V2 Configuration (Phase F10.1+) ───────────────────────────────────
# Active la nouvelle UI du builder avec preview intégrée et édition inline
# Par défaut false (V1 legacy) — passer à true pour tester Phase F10.1
NEXT_PUBLIC_BUILDER_V2=false

# Niveau de logging du Builder (debug, info, warn, error)
# debug : tous les logs (verbose)
# info : logs importants uniquement (défaut)
# warn : erreurs et warnings
# error : erreurs critiques uniquement
NEXT_PUBLIC_BUILDER_LOG_LEVEL=info

# Timeout pour render preview (ms) — trigger perf warning si dépassé
NEXT_PUBLIC_BUILDER_PREVIEW_TIMEOUT=500

# ── Stripe (optionnel) ────────────────────────────────────────────────────────
# Clé publique Stripe pour paiements réels
# Si absent : checkout désactivé, mode test uniquement
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
